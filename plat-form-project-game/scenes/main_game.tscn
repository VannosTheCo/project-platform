[sub_resource type="GDScript" id="GDScript_ygxny"]
script/source = "extends StaticBody2D

var activated = false
var speed = 100

func _on_area_2d_body_entered(body):
	if body.name == \"Player-Knight\":
		$AnimationPlayer.play(\"platform-vertical\")
		
"

